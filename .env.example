# Marktguru headers
MARKTGURU_API_KEY=your_marktguru_api_key_here
MARKTGURU_CLIENT_KEY=your_marktguru_client_key_here
MARKTGURU_API_BASE=https://api.marktguru.de/api/v1
# Optional: override image CDN host (must match next.config remotePatterns if using next/image)
# MARKTGURU_IMAGE_CDN=https://mg2de.b-cdn.net/api/v1

# Overpass
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Cron cache warmer: when set, require Authorization: Bearer <secret> OR Vercel cron (x-vercel-cron: 1)
# CRON_SECRET=your_random_secret

# App
NEXT_PUBLIC_APP_NAME=Student Sparplan Trier
